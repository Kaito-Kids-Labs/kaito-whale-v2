# ============================
# PENGATURAN WEBSOCKET
# ============================
# URL dasar WebSocket server (tanpa query string).
# Ganti sesuai alamat server kamu.
VITE_WS_URL=ws://168.231.118.74:8080/ws

# ============================
# PENGATURAN INPUT (KETUKAN)
# ============================
# Batas maksimum durasi tekan (ms) yang masih dihitung sebagai getar pendek.
# Tekan < nilai ini = getar pendek, tekan >= nilai ini = getar panjang.
VITE_INPUT_DOT_MAX_MS=150

# Waktu tunggu (ms) setelah ketukan terakhir sebelum pola diterjemahkan ke kata.
# Semakin besar nilainya, semakin lama waktu untuk menyusun pola beberapa simbol.
VITE_INPUT_PATTERN_END_DELAY_MS=2000

# Lama getaran (ms) saat tombol sedang ditekan terus-menerus.
VITE_INPUT_CONTINUOUS_VIBRATE_MS=80

# Jeda (ms) antar getaran pendek saat tombol masih ditekan (membuat efek hampir terus-menerus).
VITE_INPUT_CONTINUOUS_GAP_MS=20

# ================================
# PENGATURAN OUTPUT (TERIMA PESAN)
# ================================
# Durasi getaran (ms) untuk simbol getar pendek saat memutar pesan yang diterima.
VITE_OUTPUT_DOT_MS=180

# Durasi getaran (ms) untuk simbol getar panjang saat memutar pesan yang diterima.
VITE_OUTPUT_DASH_MS=1000

# Jeda (ms) antar simbol saat memutar pola dari pesan yang diterima.
VITE_OUTPUT_GAP_MS=800
